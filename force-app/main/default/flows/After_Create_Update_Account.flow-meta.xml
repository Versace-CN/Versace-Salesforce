        <defaultConnector>
            <targetReference>Update_Flag_Skip</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Send</defaultConnectorLabel>
        <rules>
            <name>Send</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Skip_Platform_Event__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
