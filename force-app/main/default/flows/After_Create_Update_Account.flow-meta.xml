    </formulas>
    <formulas>
        <name>GenderUpdated</name>
        <dataType>String</dataType>
        <expression>IF(
    AND(ISPICKVAL({!$Record.Gender__pc}, &quot;&quot;), ISPICKVAL({!$Record.Customer_Title__pc}, &quot;91&quot;)), 
    &quot;2&quot;, 
    IF(
        AND(ISPICKVAL({!$Record.Gender__pc}, &quot;&quot;), ISPICKVAL({!$Record.Customer_Title__pc}, &quot;93&quot;)), 
        &quot;1&quot;, 
        IF(
            AND(ISPICKVAL({!$Record.Gender__pc}, &quot;&quot;), ISPICKVAL({!$Record.Customer_Title__pc}, &quot;94&quot;)), 
            &quot;3&quot;, 
            NULL
        )
    )
)</expression>
    </formulas>
    <formulas>
        <name>IsEcommerceUpdated</name>
        <dataType>Boolean</dataType>
