    <formulas>
        <name>AgeGroupUpdated</name>
        <dataType>String</dataType>
        <expression>IF(
    ISBLANK(TEXT({!$Record.Age_Group__pc})),
    NULL,
    IF(
        ISBLANK(TEXT({!$Record.Birthdate_Year__pc})),
        TEXT({!$Record.Age_Group__pc}),
        IF(
            YEAR(TODAY()) - VALUE(TEXT({!$Record.Birthdate_Year__pc})) &lt;= 25, 
            &apos;30&apos;, 
            IF(
                YEAR(TODAY()) - VALUE(TEXT({!$Record.Birthdate_Year__pc})) &gt; 25 &amp;&amp; YEAR(TODAY()) - VALUE(TEXT({!$Record.Birthdate_Year__pc})) &lt;= 35, 
                &apos;31&apos;, 
                IF(
                    YEAR(TODAY()) - VALUE(TEXT({!$Record.Birthdate_Year__pc})) &gt; 35 &amp;&amp; YEAR(TODAY()) - VALUE(TEXT({!$Record.Birthdate_Year__pc})) &lt;= 45, 
                    &apos;41&apos;, 
                    IF(
                        YEAR(TODAY()) - VALUE(TEXT({!$Record.Birthdate_Year__pc})) &gt; 45 &amp;&amp; YEAR(TODAY()) - VALUE(TEXT({!$Record.Birthdate_Year__pc})) &lt;= 55, 
                        &apos;50&apos;, 
                        &apos;over 55&apos;
                    )
                )
            )
        )
    )
)</expression>
    </formulas>
    <formulas>
        <name>EmployeePlusOne</name>
        <dataType>Number</dataType>
        <expression>{!$Record.NumberOfEmployees}+1</expression>
